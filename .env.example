# ===== LLM (DeepSeek via OpenAI-compatible API) =====
OPENAI_API_KEY=your_deepseek_api_key
OPENAI_MODEL=deepseek-v4-flash
OPENAI_TEMPERATURE=0.3
BASE_URL=https://api.deepseek.com/v1

# ===== 豆包视觉模型（图片识别用） =====
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_VISION_MODEL=doubao-seed-2-0-pro-260215

# ===== LangSmith 追踪（可选，不需要则不填） =====
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_TRACING_V2=true
# LANGSMITH_PROJECT=mragagent

# ===== 稠密向量（文本，BGE-M3） =====
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
HF_HUB_OFFLINE=true

# ===== 图片向量（Chinese-CLIP） =====
CLIP_MODEL=ViT-L-14
CLIP_DEVICE=cpu

# ===== Rerank（可选，不配则跳过重排序） =====
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_BINDING_HOST=http://127.0.0.1:8001
RERANK_API_KEY=local-rerank-key
RERANK_DEVICE=cpu
RERANK_MAX_LENGTH=1024

# ===== Milvus =====
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_IMAGE_COLLECTION=image_poi_collection
MILVUS_TEXT_COLLECTION=text_chunk_collection

# ===== Database / Cache =====
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/mragagent
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=mragagent
REDIS_CACHE_TTL_SECONDS=300

# ===== BM25 稀疏检索 =====
BM25_STATE_PATH=data/bm25_state.json

# ===== 检索参数 =====
LEAF_RETRIEVE_LEVEL=3
AUTO_MERGE_ENABLED=true
AUTO_MERGE_THRESHOLD=2

# ===== Auth（Web 前端管理后台用） =====
ADMIN_TOKEN=mragagent-admin-token-2026

# ===== STT 语音识别（火山引擎 ASR，Unity 接入需要） =====
STT_PROVIDER=volcano
STT_APPID=your_volcano_appid
STT_ACCESS_KEY=your_volcano_access_key
STT_API_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
STT_RESOURCE_ID=volc.bigasr.auc_turbo
STT_MODEL_NAME=bigmodel

# ===== TTS 语音合成（火山引擎 TTS，Unity 接入需要） =====
TTS_PROVIDER=volcano
TTS_APPID=your_volcano_appid
TTS_ACCESS_TOKEN=your_volcano_access_token
TTS_CLUSTER=volcano_tts
TTS_VOICE_TYPE=zh_male_shaonianzixin_moon_bigtts
TTS_API_URL=https://openspeech.bytedance.com/api/v1/tts
